    <!-- REMOVED View All Bookings Button -->
    <!-- <Button mnemonicParsing="false" onAction="#handleViewBookings" text="View All Bookings" /> -->

    <!-- REMOVED View Seat Availability Button -->
    <!-- <Button mnemonicParsing="false" onAction="#handleViewSeatAvailability" text="View Seat Availability" /> -->

    <!-- REMOVED View/Delete Flights Button -->
    <!-- <Button mnemonicParsing="false" onAction="#handleViewDeleteFlights" text="View / Delete Flights" /> -->

    <!-- Kept Logout Button -->
    <Button fx:id="handleLogoutButton" mnemonicParsing="false" onAction="#handleLogout" text="Logout" />

</VBox>